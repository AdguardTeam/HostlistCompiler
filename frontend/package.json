{
    "name": "adblock-compiler-frontend",
    "version": "1.0.0",
    "description": "Angular 21 PoC for Adblock Compiler with Material Design, Zoneless Change Detection, and Cloudflare Workers SSR",
    "private": true,
    "scripts": {
        "ng": "ng",
        "start": "ng serve",
        "build": "ng build",
        "watch": "ng build --watch --configuration development",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage",
        "lint": "ng lint",
        "test:e2e": "npx playwright test --config=e2e/playwright.config.ts",
        "preview": "wrangler dev",
        "deploy": "wrangler deploy"
    },
    "dependencies": {
        "@analogjs/vite-plugin-angular": "^2.3.1",
        "@angular/animations": "^21.0.0",
        "@angular/cdk": "^21.0.0",
        "@angular/common": "^21.0.0",
        "@angular/compiler": "^21.0.0",
        "@angular/core": "^21.0.0",
        "@angular/forms": "^21.0.0",
        "@angular/material": "^21.0.0",
        "@angular/platform-browser": "^21.0.0",
        "@angular/platform-browser-dynamic": "^21.1.5",
        "@angular/platform-server": "^21.0.0",
        "@angular/router": "^21.0.0",
        "@angular/service-worker": "^21.0.0",
        "@angular/ssr": "^21.0.0",
        "@fontsource/roboto": "^5.2.5",
        "material-symbols": "^0.31.0",
        "rxjs": "~7.8.2",
        "tslib": "^2.3.0"
    },
    "devDependencies": {
        "@analogjs/vitest-angular": "^1.22.5",
        "@angular-devkit/build-angular": "^21.0.0",
        "@angular-eslint/builder": "^21.2.0",
        "@angular/cli": "^21.0.0",
        "@angular/compiler-cli": "^21.0.0",
        "@cloudflare/workers-types": "^4.0.0",
        "@playwright/test": "^1.52.0",
        "@vitest/coverage-v8": "^4.0.0",
        "angular-eslint": "^21.2.0",
        "eslint": "^9.0.0",
        "jsdom": "^28.1.0",
        "typescript": "~5.9.0",
        "typescript-eslint": "^8.56.1",
        "vitest": "^4.0.0"
    }
}
