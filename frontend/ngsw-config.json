{
    "$schema": "./node_modules/@angular/service-worker/config/schema.json",
    "index": "/index.html",
    "assetGroups": [
        {
            "name": "app",
            "installMode": "prefetch",
            "resources": {
                "files": [
                    "/favicon.ico",
                    "/index.html",
                    "/*.css",
                    "/*.js"
                ]
            }
        },
        {
            "name": "assets",
            "installMode": "lazy",
            "updateMode": "prefetch",
            "resources": {
                "files": [
                    "/assets/**"
                ]
            }
        }
    ],
    "dataGroups": [
        {
            "name": "api-freshness",
            "urls": ["/api/**"],
            "cacheConfig": {
                "strategy": "freshness",
                "maxSize": 50,
                "maxAge": "1m",
                "timeout": "5s"
            }
        },
        {
            "name": "api-performance",
            "urls": ["/api/metrics", "/api/health", "/api/version"],
            "cacheConfig": {
                "strategy": "performance",
                "maxSize": 10,
                "maxAge": "30s"
            }
        }
    ]
}
