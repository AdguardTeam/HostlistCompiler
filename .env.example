# ============================================================================
# Environment Variables Template
# ============================================================================
# Copy this file to .env.local and fill in your actual values.
#
# This project uses direnv + .envrc for ALL local environment management.
# Variables are loaded automatically when you enter the project directory.
# Run `direnv allow` once after cloning to activate.
#
# Environment Loading Order (via .envrc):
#   1. .env           - Base configuration (committed — non-secret defaults)
#   2. .env.$ENV      - Environment-specific (.env.development or .env.production)
#   3. .env.local     - Local overrides and secrets (NOT committed — your private copy)
#
# The $ENV variable is determined by your current git branch:
#   - main           → production   → loads .env.production
#   - dev/develop    → development  → loads .env.development
#   - other branches → local        → uses .env.local only
#
# ─────────────────────────────────────────────────────────────────────────────
# RULE: ALL new environment variables MUST be added here with a comment stub.
#       Do NOT add new variables directly to wrangler.toml [vars] —
#       that file is reserved for Cloudflare-specific runtime bindings only
#       (KV/D1/R2 IDs, queue names, etc.).
# ─────────────────────────────────────────────────────────────────────────────
# ============================================================================

# ===== Core / Server =====
# Server port (override .env default of 8787 for local dev)
# PORT=8787

# ===== Database Configuration =====
# Local development (SQLite for quick dev; PostgreSQL for full integration dev)
DATABASE_URL="file:./data/adblock.db"

# Direct connection string for migrations and introspection (PostgreSQL)
DIRECT_DATABASE_URL="postgres://your_user:your_password@localhost:5432/adblock_compiler"

# Prisma Accelerate connection string (optional — cloud-hosted Prisma Accelerate)
# PRISMA_DATABASE_URL="prisma+postgres://accelerate.prisma-data.net/?api_key=your_api_key_here"

# Wrangler Hyperdrive local connection (used during `wrangler dev` local tunnel)
# WRANGLER_HYPERDRIVE_LOCAL_CONNECTION_STRING_HYPERDRIVE=postgresql://user:password@host:5432/postgres?sslmode=verify-full&sslrootcert=system

# ===== Clerk Authentication =====
# Get keys from https://dashboard.clerk.com → API Keys
# Publishable key (public — starts with pk_test_ or pk_live_)
CLERK_PUBLISHABLE_KEY=pk_test_your_publishable_key_here
# Secret key (private — starts with sk_test_ or sk_live_ — NEVER commit real value)
CLERK_SECRET_KEY=sk_test_your_secret_key_here
# JWKS endpoint URL (derived from your Clerk Frontend API URL)
# Format: https://<your-frontend-api>.clerk.accounts.dev/.well-known/jwks.json
CLERK_JWKS_URL=https://your-instance.clerk.accounts.dev/.well-known/jwks.json
# Webhook signing secret from Clerk Dashboard → Webhooks → Endpoint → Signing Secret
CLERK_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# ===== Cloudflare Access (admin defense-in-depth — optional) =====
# Get from Cloudflare Zero Trust Dashboard → Access → Applications
# CF_ACCESS_TEAM_DOMAIN=your-team-name
# CF_ACCESS_AUD=your-audience-tag-here

# ===== CORS (Zero Trust — allowlist for authenticated/write endpoints) =====
# Comma-separated list of allowed origins. Public read-only endpoints always use *.
# For local dev, defaults to localhost:4200 and localhost:8787 if not set.
# For production, set via `wrangler secret put CORS_ALLOWED_ORIGINS` or CI secrets.
# CORS_ALLOWED_ORIGINS=http://localhost:4200,http://localhost:8787,https://adblock-compiler.pages.dev

# ===== Cloudflare Turnstile (bot protection — optional) =====
# Get your keys from https://dash.cloudflare.com/?to=/:account/turnstile
# Site key (public — used in the frontend widget)
TURNSTILE_SITE_KEY=1x00000000000000000000AA
# Secret key (private — used for server-side validation)
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA

# ===== Admin API Key (legacy — will be replaced by Clerk tier auth) =====
# Used with X-Admin-Key header for legacy admin endpoints
ADMIN_KEY="your_admin_key_here"

# ===== Request Body Limits =====
# Maximum request body size in megabytes (defaults to 1MB if not set)
# Helps prevent DoS attacks via large payloads
MAX_REQUEST_BODY_MB="1"

# ===== Cloudflare API (CI/CD and scripts) =====
# Used by scripts that call the Cloudflare API directly (not the Worker runtime)
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token_here
CLOUDFLARE_ACCOUNT_ID=your_account_id_here

# ===== Cloudflare Web Analytics =====
# Get your token from https://dash.cloudflare.com/?to=/:account/web-analytics
# This token is injected into index.html at build time by scripts/build-worker.sh.
CF_WEB_ANALYTICS_TOKEN=your_web_analytics_token_here

# ===== Logging & Observability =====
# Log level: trace | debug | info | warn | error (default: info)
# LOG_LEVEL=info
# Enable structured JSON log output (default: false)
# LOG_STRUCTURED=false
# Per-module log level overrides (e.g. compiler:debug,worker:warn)
# LOG_MODULE_OVERRIDES=
# Log retention TTL in seconds (default: 604800 = 7 days)
# LOG_RETENTION_TTL=604800
# External log sink (e.g. Logtail, Axiom, Datadog HTTP API)
# LOG_SINK_URL=https://your-log-sink.example.com/ingest
# LOG_SINK_TOKEN=your_log_sink_token_here
# Minimum level to forward to external sink (default: warn)
# LOG_SINK_MIN_LEVEL=warn

# ===== Error Reporting & Observability =====
# Error reporter backend: console | cloudflare | sentry | composite (default: console)
# ERROR_REPORTER_TYPE=console
# Enable verbose error logging (default: false)
# ERROR_REPORTER_VERBOSE=false
# Sentry DSN (required when ERROR_REPORTER_TYPE=sentry or when Sentry integration is enabled)
# Get from: Sentry Dashboard → Projects → adblock-compiler → Settings → Client Keys (DSN)
# ⚠ NEVER commit a real DSN. Always use wrangler secret put SENTRY_DSN.
# Set as a Worker secret in production: wrangler secret put SENTRY_DSN
# SENTRY_DSN=https://your-key@oNNNNNN.ingest.sentry.io/your-project-id
# OpenTelemetry OTLP exporter endpoint (required when using OTel traces/metrics).
# Supported backends: Grafana Cloud OTLP, Honeycomb, Dash0, Jaeger, etc.
# Set as a Worker secret: wrangler secret put OTEL_EXPORTER_OTLP_ENDPOINT
# OTEL_EXPORTER_OTLP_ENDPOINT=https://otlp.grafana.net/otlp
# Datadog API key (optional — for Datadog error/metrics integration)
# DATADOG_API_KEY=your_datadog_api_key_here

# ===== Analytics Engine SQL API (Prometheus /metrics endpoint) =====
# Required only for the GET /metrics/prometheus scrape endpoint.
# The binding name "ANALYTICS_ENGINE" is already wired in wrangler.toml.
# These two secrets allow the handler to query the Analytics Engine SQL API at runtime.
# Obtain ANALYTICS_API_TOKEN with "Account Analytics Read" permission from:
#   https://dash.cloudflare.com/profile/api-tokens
# Set both as Worker secrets: wrangler secret put ANALYTICS_ACCOUNT_ID
#                             wrangler secret put ANALYTICS_API_TOKEN
# ANALYTICS_ACCOUNT_ID=your_cloudflare_account_id_here
# ANALYTICS_API_TOKEN=your_analytics_read_api_token_here

# ===== Notifications & Webhooks =====
# Generic HTTP webhook for POST /api/notify
# WEBHOOK_URL=https://your-webhook-endpoint.example.com/hook
# Discord webhook for notifications
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your-id/your-token
# Slack webhook for notifications
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/slack/webhook

# ===== Optimize =====
# OPTIMIZE_API_KEY="your_optimize_api_key_here"

# ===== Warp =====
# WARP_API_KEY=your_warp_api_key

# ===== Testing & Local Development =====
# Base URL for E2E and contract tests
# E2E_BASE_URL=http://localhost:8787
# Set to "true" to skip OpenAPI contract tests (e.g. in offline CI)
# SKIP_CONTRACT_TESTS=false
# Storage backend selection: memory | prisma (default: prisma in production, memory in tests)
# STORAGE_BACKEND=memory
# D1 database ID (used by scripts that reference D1 directly, not the worker runtime binding)
# D1_DATABASE_ID=your-d1-database-id-here

# ===== Angular Frontend =====
# The frontend runs on port 4200 by default (ng serve).
# The backend Wrangler dev server runs on port 8787.
# In local dev, the frontend proxies /api requests to the backend.
#
# To build the frontend:  pnpm --filter adblock-compiler-frontend build
# To serve locally:       pnpm --filter adblock-compiler-frontend start
# To run frontend tests:  pnpm --filter adblock-compiler-frontend test
# To lint frontend:       pnpm --filter adblock-compiler-frontend lint
# To run E2E tests:       pnpm --filter adblock-compiler-frontend test:e2e
