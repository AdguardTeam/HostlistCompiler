{
    "name": "adblock-compiler",
    "version": "0.43.1",
    "description": "Compiler-as-a-Service for adblock filter lists",
    "type": "module",
    "scripts": {
        "ui:build": "pnpm --filter adblock-compiler-frontend run build",
        "ui:dev": "pnpm --filter adblock-compiler-frontend run start",
        "ui:test": "pnpm --filter adblock-compiler-frontend run test",
        "ui:lint": "pnpm --filter adblock-compiler-frontend run lint",
        "build:worker": "pnpm install && pnpm --filter adblock-compiler-frontend run build"
    },
    "packageManager": "pnpm@9.15.0",
    "_syncNote": "Dependency versions here must match those pinned in deno.json's import map; keep them in sync (for example via the existing version:sync-style task).",
    "dependencies": {
        "@adguard/agtree": "^4.0.1",
        "@opentelemetry/api": "^1.9.0",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@cloudflare/playwright-mcp": "^0.0.5",
        "wrangler": "^4.71.0"
    }
}
